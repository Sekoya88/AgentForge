# Copy to repo root: cp .env.example .env
# Local stack: ./scripts/dev-up.sh  (Docker: db + redis + alembic)
#
# Backend
# Use port 5433 / 6380 when using `docker compose up -d db redis` from this repo.
DATABASE_URL=postgresql+asyncpg://forge:forge@localhost:5433/agentforge
REDIS_URL=redis://localhost:6380/0
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Frontend dev URLs (comma-separated). Include both if you switch between localhost and 127.0.0.1.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Chrome sends Access-Control-Request-Private-Network on some cross-origin calls; keep true for local dev.
CORS_ALLOW_PRIVATE_NETWORK=true
# Any port on localhost / 127.0.0.1 (Next dev often uses 3001 if 3000 is taken). Set to empty to disable.
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$

# Red-team: mock (default, no Node) | promptfoo (requires npx + promptfoo)
REDTEAM_MODE=mock

# Optional — LLM keys (wired in Settings; orchestrator still stub — future real calls)
OPENAI_API_KEY=
# Gemini / Google GenAI SDK
GOOGLE_API_KEY=

# Optional — Modal (later phases)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
